// EXPECT_OK
// Demonstrates fixed agents whose output is *derived from the input*,
// not canned. Each agent below produces something that depends on what
// it was given.
//
// CHECK: complexity = 3
// CHECK: route = "error_handler"
// CHECK: safe = false
// CHECK: reason = "contains: password"
// CHECK: extracted = "the quick brown fox jumps"

agent Plan       = FixedAgent(Planner);
agent Route      = FixedAgent(Router);
agent Guard      = FixedAgent(Guardrail);
agent Extract    = FixedAgent(Extractor);

// Planner's complexity = word count of the goal (3 here).
let plan      = Plan("research quantum computing");

// Router selects a route from keywords in the input.
let routed    = Route("error: connection failed");

// Guardrail blocks content containing sensitive keywords.
let guard     = Guard("here is my password: hunter2");

// Extractor takes the first 5 words of the source.
let snippet   = Extract("the quick brown fox jumps over the lazy dog")
