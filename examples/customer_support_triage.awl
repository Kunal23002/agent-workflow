config {
  real_llm = true,
  llm_model = "claude-opus-4-7"
};

agent Clean      = FixedAgent(Cleaner);
agent Guard      = FixedAgent(Guardrail);
agent Extract    = FixedAgent(Extractor);
agent Route      = FixedAgent(Router);
agent Draft      = FixedAgent(Writer);
agent Validate   = FixedAgent(Validator);
agent Critique   = FixedAgent(Critic);
agent Summarize  = FixedAgent(Summarizer);

let ticket = "Customer says their subscription was charged twice after upgrading to the Pro plan. They are frustrated and want a refund or account credit. Order ID: ORD-88421. Email: customer@example.com.";

let cleaned    = Clean(ticket);
let safety     = Guard(cleaned.output);
let facts      = Extract(safety.output);
let route      = Route(facts.output);
let draft      = Draft({ route = route.output, facts = facts.output, original_ticket = ticket });
let validation = Validate(draft.output);
let critique   = Critique(validation.output);
let summary    = Summarize({ route = route.output, draft = draft.output, critique = critique.output });

print "--- cleaned ticket ---";
print cleaned.output;
print "--- safety check ---";
print safety.output;
print "--- extracted facts ---";
print facts.output;
print "--- route ---";
print route.output;
print "--- drafted response ---";
print draft.output;
print "--- validation ---";
print validation.output;
print "--- critique ---";
print critique.output;
print "--- final summary ---";
print summary.output;

let result = {
  ticket = ticket,
  route = route.output,
  drafted_response = draft.output,
  validation = validation.output,
  critique = critique.output,
  summary = summary.output
}
